# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/app/\[locale\]/test-loading/
/test-results/
/playwright-report/

# serwist (generated service worker)
public/sw.js
public/sw.js.map

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
CREDENTIALS.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/lib/generated/prisma
/data/
